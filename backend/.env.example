# Copy to .env and adjust as needed. All values have sensible defaults.
# QDRANT_MODE=local runs Qdrant embedded/in-process (no Docker) and persists to
# QDRANT_PATH. Set QDRANT_MODE=server to use a Qdrant server (docker-compose).
QDRANT_MODE=local
QDRANT_PATH=./qdrant_storage
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=biology_rag

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest

CHUNK_SIZE=750
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=10
TOP_K_RERANK=4

PDF_DIR=./pdfs
FINGERPRINT_FILE=./fingerprints/indexed_docs.json
LOG_DIR=./logs
MAX_LATENCY_TARGET_MS=5000
